# ============================================================================
# REQUIRED - CORE FUNCTIONALITY
# ============================================================================

# ============================================================================
# API KEY - DASHSCOPE_API_KEY (same as QWEN API key from QwenCloud)
# ============================================================================
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen3.7-plus
QWEN_TEMPERATURE=0.3
QWEN_TOP_P=0.65

# ============================================================================
# QWEN/DASHSCOPE ENDPOINT CONFIGURATION
# ============================================================================
# Choose one of the following endpoints based on where you created your API key:
#
# Option 1: DashScope (dashscope.console.aliyun.com) - DEFAULT
#   Leave DASHSCOPE_ENDPOINT commented out
#
# Option 2: QwenCloud (home.qwencloud.com) - INTERNATIONAL ENDPOINT
#   Uses -intl subdomain for international access:
DASHSCOPE_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ============================================================================
# ROBINHOOD AGENTIC TRADING CONFIGURATION (OAuth 2.1 PKCE)
# ============================================================================
# MCP Endpoint for agentic trading
ROBINHOOD_MCP_ENDPOINT=https://agent.robinhood.com/mcp/trading

# Your Robinhood Account ID (for agentic trading)
ROBINHOOD_ACCOUNT_ID=your_robinhood_account_id_here

# Enable OAuth-based trading (tokens managed automatically)
ROBINHOOD_TRADING_ENABLED=true
# Note: OAuth tokens are cached in ~/.robinhood_agent/tokens/ (not in .env)
# First trade request will prompt you to log in via browser + 2FA

# ============================================================================
# BACKEND/FRONTEND SETTINGS
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8002
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=info

FRONTEND_HOST=localhost
FRONTEND_PORT=8501

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
DEBUG=false
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
REPORT_FORMAT=markdown
REPORT_INCLUDE_CHARTS=true

# ============================================================================
# LOGGING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE_PATH=logs/app.log

# ============================================================================
# SECURITY (Production Only)
# ============================================================================

# JWT Secret key (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_min_32_chars

# HTTPS
SECURE=false
SSL_CERT_FILE=
SSL_KEY_FILE=