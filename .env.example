# Environment Configuration - COPY TO .env AND FILL IN YOUR VALUES
# Never commit .env to version control!

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=info

# Frontend settings
FRONTEND_HOST=localhost
FRONTEND_PORT=8501

# API timeout (seconds)
API_REQUEST_TIMEOUT=60

# ============================================================================
# LLM CONFIGURATION
# ============================================================================

# Qwen (Alibaba) - PRIMARY LLM
# Get your API key from: https://dashscope.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-max
QWEN_TEMPERATURE=0.7
QWEN_TOP_P=0.85

# OpenAI (Optional - for fallback)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo

# Anthropic (Optional - for fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# ============================================================================
# FINANCIAL DATA API CONFIGURATION (Optional)
# ============================================================================

# Alpha Vantage (stock data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub (financial news & data)
FINNHUB_API_KEY=your_finnhub_key_here

# ============================================================================
# DATABASE CONFIGURATION (Optional - for production persistence)
# ============================================================================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/corporate_intelligence
DATABASE_ECHO=false

# Redis (caching)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================================================

# LangSmith (LLM tracing)
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=corporate-intelligence-engine

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn_here

# ============================================================================
# AWS CONFIGURATION (Optional - for cloud deployment)
# ============================================================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# S3 bucket for report storage
S3_BUCKET_NAME=corporate-intelligence-reports

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Debug mode
DEBUG=false

# Environment
ENVIRONMENT=development

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Agent configuration
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=30

# Report settings
REPORT_FORMAT=markdown
REPORT_INCLUDE_CHARTS=true

# ============================================================================
# LOGGING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE_PATH=logs/app.log

# ============================================================================
# SECURITY (Production Only)
# ============================================================================

# JWT Secret key (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_min_32_chars

# HTTPS
SECURE=false
SSL_CERT_FILE=
SSL_KEY_FILE=
